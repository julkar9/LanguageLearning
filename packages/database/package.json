{
  "name": "@language-learning/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:seed": "tsx src/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@language-learning/api-contract": "workspace:*",
    "@prisma/client": "6.19.3"
  },
  "devDependencies": {
    "prisma": "6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
