generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id        String   @id @default(cuid())
  title     String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudyItem {
  id              String @id
  category        String
  level           String
  prompt          String
  reading         String
  meaning         String
  acceptedAnswers Json
  explanation     String
  keyboardTip     String
  examples        Json
}

model KanaQuizItem {
  id              String @id
  script          String
  prompt          String
  target          String
  acceptedAnswers Json
  romaji          String
  keyboardTip     String
  explanation     String
}

model DailyWordPair {
  id         String @id
  title      String
  english    Json
  japanese   Json
  microStory String
}

model ReadingLabPassage {
  id               String @id
  title            String
  theme            String
  difficulty       String
  estimatedMinutes Int
  focus            String
  passage          Json
  argumentMap      Json
  discourseMarkers Json
  vocabulary       Json
  traps            Json
  questions        Json
  paraphrases      Json
  rereadPlan       Json
  summaryChallenge String
}

model LearnerMemory {
  id      String @id
  payload Json
}
